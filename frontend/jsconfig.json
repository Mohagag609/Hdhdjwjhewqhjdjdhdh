{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "*": ["*"],
      "components/*": ["components/*"],
      "pages/*": ["pages/*"],
      "services/*": ["services/*"],
      "contexts/*": ["contexts/*"],
      "types/*": ["types/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}