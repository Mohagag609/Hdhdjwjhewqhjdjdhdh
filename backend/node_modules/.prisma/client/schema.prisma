// Prisma schema will be filled next
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        Int       @id @default(autoincrement())
  name      String
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())

  phases      Phase[]
  partners    ProjectPartner[]
  materials   MaterialItem[]
  treasury    TreasuryTransaction[]
  settlements PartnerPhaseSettlement[]
}

model Phase {
  id            Int      @id @default(autoincrement())
  projectId     Int
  name          String
  plannedAmount Decimal?
  createdAt     DateTime @default(now())

  project     Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materials   MaterialItem[]
  treasury    TreasuryTransaction[]
  settlements PartnerPhaseSettlement[]
}

model Partner {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  projects    ProjectPartner[]
  treasury    TreasuryTransaction[]
  settlements PartnerPhaseSettlement[]

  @@unique([name])
}

model ProjectPartner {
  projectId  Int
  partnerId  Int
  percentage Decimal

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  @@id([projectId, partnerId])
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  materials MaterialItem[]
  treasury  TreasuryTransaction[]

  @@unique([name])
}

model MaterialItem {
  id         Int      @id @default(autoincrement())
  projectId  Int
  phaseId    Int
  supplierId Int
  name       String
  quantity   Decimal
  unit       String?
  unitPrice  Decimal
  total      Decimal  @default(0)
  createdAt  DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase    Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  treasury TreasuryTransaction[]
}

enum Direction {
  in
  out
}

model TreasuryTransaction {
  id             Int       @id @default(autoincrement())
  projectId      Int
  direction      Direction
  amount         Decimal
  txDate         DateTime  @default(now())
  reference      String?
  partnerId      Int?
  supplierId     Int?
  phaseId        Int?
  materialItemId Int?
  method         String?
  notes          String?

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partner  Partner?      @relation(fields: [partnerId], references: [id])
  supplier Supplier?     @relation(fields: [supplierId], references: [id])
  phase    Phase?        @relation(fields: [phaseId], references: [id])
  material MaterialItem? @relation(fields: [materialItemId], references: [id])
}

enum SettlementStatus {
  none
  needs_to_pay
  needs_refund
  settled
}

model PartnerPhaseSettlement {
  id               Int              @id @default(autoincrement())
  projectId        Int
  phaseId          Int
  partnerId        Int
  amountDue        Decimal
  amountPaidToDate Decimal
  delta            Decimal
  status           SettlementStatus
  createdAt        DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase   Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  @@unique([projectId, phaseId, partnerId])
}

// Prisma lacks computed stored columns; we'll compute MaterialItem.total in service
